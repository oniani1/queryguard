{
  "name": "qguard",
  "version": "0.3.1",
  "description": "Detect N+1 queries at the driver level. Zero config. Works with any ORM.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oniani1/queryguard.git"
  },
  "homepage": "https://oniani1.github.io/queryguard",
  "bugs": "https://github.com/oniani1/queryguard/issues",
  "keywords": [
    "n-plus-one",
    "n+1",
    "query",
    "performance",
    "database",
    "sql",
    "orm",
    "prisma",
    "drizzle",
    "typeorm",
    "knex",
    "postgres",
    "mysql",
    "testing",
    "vitest",
    "typescript"
  ],
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vitest": {
      "import": "./dist/integrations/vitest.js",
      "require": "./dist/integrations/vitest.js",
      "types": "./dist/integrations/vitest.d.ts"
    },
    "./jest": {
      "import": "./dist/integrations/jest.js",
      "require": "./dist/integrations/jest.js",
      "types": "./dist/integrations/jest.d.ts"
    },
    "./express": {
      "import": "./dist/middleware/express.js",
      "require": "./dist/middleware/express.js",
      "types": "./dist/middleware/express.d.ts"
    },
    "./next": {
      "import": "./dist/middleware/next.js",
      "require": "./dist/middleware/next.js",
      "types": "./dist/middleware/next.d.ts"
    },
    "./hono": {
      "import": "./dist/middleware/hono.js",
      "require": "./dist/middleware/hono.js",
      "types": "./dist/middleware/hono.d.ts"
    },
    "./fastify": {
      "import": "./dist/middleware/fastify.js",
      "require": "./dist/middleware/fastify.js",
      "types": "./dist/middleware/fastify.d.ts"
    },
    "./notifiers": {
      "import": "./dist/notifiers/index.js",
      "require": "./dist/notifiers/index.js",
      "types": "./dist/notifiers/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "bench": "vitest bench",
    "bench:ci": "node --import tsx bench/overhead-ci.ts",
    "lint": "biome check src/",
    "format": "biome format --write src/ test/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "peerDependencies": {
    "@jest/globals": ">=29.0.0",
    "express": ">=4.0.0",
    "fastify": ">=4.0.0",
    "hono": ">=4.0.0",
    "mysql2": ">=3.0.0",
    "pg": ">=8.0.0",
    "vitest": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "vitest": {
      "optional": true
    },
    "@jest/globals": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@hono/node-server": "^1.19.14",
    "@types/express": "^5.0.0",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^3.2.4",
    "express": "^5.1.0",
    "fast-check": "^4.6.0",
    "fastify": "^5.0.0",
    "hono": "^4.0.0",
    "mysql2": "^3.22.0",
    "pg": "^8.16.0",
    "tinybench": "^6.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
